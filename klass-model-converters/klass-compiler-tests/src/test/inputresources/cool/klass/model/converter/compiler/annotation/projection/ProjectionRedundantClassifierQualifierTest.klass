package dummy

class Parent
{
    id: Long key;
    parentChildId: Long private;
}

class Child
{
    id: Long key;
}

association ParentHasChild
{
    parent: Parent[1..1];
    child: Child[0..1];

    relationship this.parentChildId == Child.id
}

projection ChildProjection on Child
{
    id: "Child ID",
}

projection DataTypePropertyProjection on Parent
{
    Parent.id: "ID",
}

projection ReferencePropertyProjection on Parent
{
    Parent.child:
    {
        id: "Child ID",
    },
}

projection ProjectionReferenceProjection on Parent
{
    Parent.child: ChildProjection,
}
